          "listen": "test",
          "script": {
            "exec": [
              "// Check status code\r",
              "pm.test(\"Status is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "// Validate response contains name and job\r",
              "var data = pm.response.json();\r",
              "pm.test(\"Response has name\", function () {\r",
              "    pm.expect(data.name).to.eql(\"Shruti\");\r",
              "});\r",
              "pm.test(\"Response has job\", function () {\r",
              "    pm.expect(data.job).to.eql(\"Tester\");\r",
              "});"
            ],
